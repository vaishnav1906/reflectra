# Example environment variables for the lightweight Vercel backend
# Copy this to backend/.env and fill values for local testing.

# Managed inference endpoint (Mistral or other provider)
MISTRAL_API_URL=https://api.mistral.ai/v1/infer
MISTRAL_API_KEY=your_mistral_api_key_here

# Frontend build-time URL (set when building frontend)
# e.g. https://<your-vercel-project>.vercel.app/api
VITE_BACKEND_URL=http://localhost:8000/api

# Optional: disable debug in production
DEBUG=false
# LLM API Configuration - Choose one or more
# Mistral AI (recommended for cost-effective performance)
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenAI (GPT models)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Backend Configuration
HOST=0.0.0.0
PORT=8000
