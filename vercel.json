{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build"
    },
    "backend": {
      "entrypoint": "backend/vercel_app",
      "routePrefix": "/api",
      "framework": "fastapi",
      "buildCommand": "pip install -r ../requirements.vercel.txt"
    }
  }
}